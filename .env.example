# ---------------------------------------------------------------------------
# .env.example — copy to .env locally; mirror in Railway service variables.
# Never commit .env.
# ---------------------------------------------------------------------------

# --- Django ---
DJANGO_SECRET_KEY=replace-me-with-a-real-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# Local Postgres via docker-compose. Railway auto-injects DATABASE_URL in prod.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lglp_dev

# --- Feature flags ---
# When False, the app runs as the fixture user `wesley@local` (auto-created)
# and bypasses Google OAuth. Set True once OAuth env vars are configured.
ENABLE_AUTH=False

# --- Google OAuth (django-allauth) ---
# Create OAuth credentials at https://console.cloud.google.com.
# Authorized redirect URI: <your-app-url>/accounts/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Comma-separated allowlist. Only these emails can sign in for v0.1.
GOOGLE_OAUTH_ALLOWED_EMAILS=j.wesley.kirk@gmail.com

# --- AI (OpenRouter) ---
# When unset, the async extraction task no-ops and logs a skip message.
OPENROUTER_API_KEY=
# TODO-verify: confirm current latest Sonnet slug on openrouter.ai
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
