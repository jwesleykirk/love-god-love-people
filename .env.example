# ---------------------------------------------------------------------------
# .env.example — copy to .env locally; mirror in Railway service variables.
# Never commit .env.
# ---------------------------------------------------------------------------

# --- Django ---
DJANGO_SECRET_KEY=replace-me-with-a-real-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Local Postgres via docker-compose. Railway auto-injects this in production.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/prototype_dev

# --- Microsoft Entra (OIDC auth) ---
# Create an app registration in the S3 Entra tenant, then fill these in.
# See: https://learn.microsoft.com/en-us/entra/identity-platform/quickstart-register-app
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8000/oidc/callback/

# --- AI (OpenRouter) ---
OPENROUTER_API_KEY=
# TODO-verify: confirm current latest Sonnet slug on openrouter.ai
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
